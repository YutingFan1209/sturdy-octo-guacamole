@model MovieShopMVC.Models.Movie
@{
    ViewData["Title"] = Model.Title;
    string releaseDate = Model.ReleaseDate == DateTime.MinValue ? "N/A" : Model.ReleaseDate.ToString("yyyy/M/d");
}

@if (TempData["Success"] is string success) { <div class="alert alert-success">@success</div> }
@if (TempData["Error"] is string error) { <div class="alert alert-danger">@error</div> }

<section class="reference-hero">
    <img src="@Model.PosterUrl" alt="@Model.Title poster" class="reference-poster" />
    <div class="reference-info" style="background-image:linear-gradient(rgba(17,52,65,.79),rgba(17,52,65,.79)),url('@Model.BackdropUrl')">
        <div class="movie-copy">
            <h1>@Model.Title</h1>
            @if (!string.IsNullOrWhiteSpace(Model.Tagline))
            {
                <p class="tagline">@Model.Tagline</p>
            }
            <div class="metadata">
                <span>@Model.Runtime m</span><span>|</span><span>@releaseDate</span>
                @foreach (string genre in (Model.Genres.Count > 0 ? Model.Genres : [Model.Genre]))
                {
                    <span class="mini-badge">@genre</span>
                }
            </div>
            <span class="score">@Model.Rating.ToString("0.0")</span>
            <p class="overview">@Model.Overview</p>
        </div>
        <div class="hero-actions">
            <button class="btn btn-dark" data-bs-toggle="modal" data-bs-target="#reviewModal">✎ Review</button>
            <button class="btn btn-light" data-bs-toggle="modal" data-bs-target="#buyModal">BUY $@Model.Price.ToString("0.00")</button>
        </div>
    </div>
</section>

<div class="detail-lower">
    <aside class="movie-facts">
        <h2>MOVIE FACTS</h2>
        <dl>
            <div><dt>▣ Release Date</dt><dd>@releaseDate</dd></div>
            <div><dt>⌛ Run Time</dt><dd>@Model.Runtime</dd></div>
            <div><dt>▧ Box Office</dt><dd>$@Model.Revenue.ToString("N2")</dd></div>
            <div><dt>$ Budget</dt><dd>$@Model.Budget.ToString("N2")</dd></div>
        </dl>
        <h2 class="trailer-heading">Trailer</h2>
        <div class="trailer-list">
            @foreach (var trailer in Model.Trailers)
            {
                <a href="@trailer.Url" target="_blank" rel="noopener">▣ @trailer.Name</a>
            }
        </div>
    </aside>
    <section class="cast-list">
        <h2>CAST</h2>
        @if (Model.Casts.Count == 0) { <p class="text-muted">Cast information coming soon.</p> }
        @foreach (var cast in Model.Casts)
        {
            <div class="cast-row">
                @if (!string.IsNullOrWhiteSpace(cast.ProfileUrl))
                { <img src="@cast.ProfileUrl" alt="@cast.Name" /> }
                else
                { <span class="cast-placeholder">@cast.Name[0]</span> }
                <span>@cast.Name</span><span>@cast.Character</span>
            </div>
        }
    </section>
</div>

@if (Model.Reviews.Count > 0)
{
    <section class="reviews-plain">
        <h2>REVIEWS</h2>
        @foreach (var review in Model.Reviews)
        { <p><strong>@review.Name (@review.Rating/10)</strong><br />@review.Comment</p> }
    </section>
}

<div class="modal fade" id="buyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5 class="modal-title">Buy @Model.Title</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
        <form asp-action="Buy" method="post"><div class="modal-body"><input type="hidden" name="movieId" value="@Model.Id" /><label class="form-label">Email</label><input name="email" type="email" required class="form-control" /></div><div class="modal-footer"><button class="btn btn-primary">Pay $@Model.Price.ToString("0.00")</button></div></form>
    </div></div>
</div>
<div class="modal fade" id="reviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5 class="modal-title">Review @Model.Title</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
        <form asp-action="AddReview" method="post"><div class="modal-body row g-3"><input type="hidden" name="MovieId" value="@Model.Id" /><div class="col-8"><label class="form-label">Name</label><input name="Name" required class="form-control" /></div><div class="col-4"><label class="form-label">Rating</label><input name="Rating" type="number" min="1" max="10" value="8" required class="form-control" /></div><div class="col-12"><label class="form-label">Comment</label><textarea name="Comment" required class="form-control"></textarea></div></div><div class="modal-footer"><button class="btn btn-primary">Post Review</button></div></form>
    </div></div>
</div>
