<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MovieShopMVC</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MovieShopMVC.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-light bg-white border-bottom mb-3">
            <div class="container-fluid px-3">
                <a class="navbar-brand" asp-controller="Movies" asp-action="Index">MovieShopMVC</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Genres</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Movies" asp-action="Index" asp-route-genre="Action">Action</a></li>
                                <li><a class="dropdown-item" asp-controller="Movies" asp-action="Index" asp-route-genre="Drama">Drama</a></li>
                                <li><a class="dropdown-item" asp-controller="Movies" asp-action="Index" asp-route-genre="Science Fiction">Science Fiction</a></li>
                                <li><a class="dropdown-item" asp-controller="Movies" asp-action="Index" asp-route-genre="Animation">Animation</a></li>
                            </ul>
                        </li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                    </ul>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-muted">Hello, @User.Identity.Name</span>
                            <form asp-controller="Account" asp-action="Logout" method="post"><button class="btn btn-outline-primary btn-sm">Logout</button></form>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex gap-2">
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-sm">Login</a>
                            <a asp-controller="Account" asp-action="Register" class="btn btn-outline-primary btn-sm">Register</a>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container page-shell">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - MovieShopMVC - <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
